# ThreatSense Environment Variables

# Database
DATABASE_URL=postgresql://threatsense:threatsense_password@localhost:5432/threatsense

# For SQLite (development):
# DATABASE_URL=sqlite:///./threatsense.db

# API
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Nuclei (optional - will use mock scanner if not available)
NUCLEI_PATH=/usr/local/bin/nuclei
