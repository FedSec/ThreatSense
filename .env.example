# Database
DATABASE_URL=postgresql+psycopg://threatsense:threatsense_password@localhost:5432/threatsense

# API
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:13000
ALLOWED_ORIGINS=http://localhost:13000,http://127.0.0.1:13000,http://localhost:3000,http://127.0.0.1:3000

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# Frontend — use /api (Next.js proxy) so the UI works on any host/port.
# For direct browser→API calls instead, set an absolute URL e.g. http://localhost:8000
NEXT_PUBLIC_API_BASE=/api
API_INTERNAL_URL=http://localhost:8000

# SMTP (Mailpit locally: UI at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@threatsense.local
SMTP_TLS=false
SMTP_USER=
SMTP_PASSWORD=

# Stripe (optional — without keys, billing uses local plan upgrade)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# AI (optional)
ANTHROPIC_API_KEY=

# Nuclei
NUCLEI_PATH=/usr/local/bin/nuclei

# Mobile
EXPO_PUBLIC_API_BASE=http://localhost:8000
